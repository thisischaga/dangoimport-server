# Example .env file for dangoimport-server
# Copy this to .env and update with your actual values

# ═════════════════════════════════════════════════
# DATABASE
# ═════════════════════════════════════════════════
MONGODB_URI=mongodb://localhost:27017/dangoimport
# OR for cloud MongoDB:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dangoimport

# ═════════════════════════════════════════════════
# SERVER
# ═════════════════════════════════════════════════
PORT=8000
NODE_ENV=development
# NODE_ENV=production

# ═════════════════════════════════════════════════
# JWT AUTHENTICATION
# ═════════════════════════════════════════════════
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRE=7d

# ═════════════════════════════════════════════════
# PAYDUNYA (Mobile Money Payment)
# ═════════════════════════════════════════════════
PAYDUNYA_MASTER_KEY=your_paydunya_master_key
PAYDUNYA_PRIVATE_KEY=your_paydunya_private_key
PAYDUNYA_PUBLIC_KEY=your_paydunya_public_key
PAYDUNYA_TOKEN=your_paydunya_token
PAYDUNYA_MODE=test
# PAYDUNYA_MODE=live (en production)

# ═════════════════════════════════════════════════
# FEDAPAY (Alternative Payment Gateway)
# ═════════════════════════════════════════════════
FEDAPAY_SECRET_KEY=your_fedapay_secret_key
FEDAPAY_ENVIRONMENT=live
# live = clés sk_live_... | sandbox = clés sk_sandbox_...
# Si omis, détecté automatiquement depuis le préfixe de la clé secrète
FEDAPAY_RETURN_URL=https://www.dangoimport.com/checkout
FEDAPAY_WEBHOOK_SECRET=your_fedapay_webhook_secret

# ═════════════════════════════════════════════════
# SOURCING — notif équipe WhatsApp (optionnel)
# ═════════════════════════════════════════════════
# TEAM_WHATSAPP_NUMBER=22890000000
# WHATSAPP_NOTIFY_URL=https://your-webhook.example/notify

# ═════════════════════════════════════════════════
# EMAIL (Resend Service)
# ═════════════════════════════════════════════════
RESEND_API_KEY=your_resend_api_key

# ═════════════════════════════════════════════════
# FRONTEND URLs (CORS)
# ═════════════════════════════════════════════════
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# ═════════════════════════════════════════════════
# DEPLOYMENT URLs
# ═════════════════════════════════════════════════
API_URL=https://dangoimport-server.onrender.com
# Utilisé pour les webhhoks de paiement

# ═════════════════════════════════════════════════
# CLOUDINARY (images produits)
# ═════════════════════════════════════════════════
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ═════════════════════════════════════════════════
# REDIS (Optional - for caching)
# ═════════════════════════════════════════════════
# REDIS_URL=redis://localhost:6379

# ═════════════════════════════════════════════════
# LOGGING
# ═════════════════════════════════════════════════
# LOG_LEVEL=info
# DEBUG=false
